# Copy this file to .env and fill in your values
# Usage: cp .env.example .env

# MongoDB connection string
# Local:  mongodb://127.0.0.1:27017/spotify_clone
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/spotify_clone
MONGO_URI=mongodb://127.0.0.1:27017/spotify_clone

# Express server port (default: 5000)
PORT=5000

# Session secret - change this to a long random string in production!
SESSION_SECRET=spotify_clone_secret_key_change_me
